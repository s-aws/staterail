{
  "ledger_path": "data/cfm-live-audit.jsonl",
  "bot": {
    "rest": {
      "execution_mode": "live",
      "retry": {
        "max_attempts": 3,
        "initial_delay_seconds": 0.25,
        "max_delay_seconds": 2,
        "multiplier": 2
      }
    },
    "feed": {
      "min_live_sources": 2,
      "stale_after_seconds": 30,
      "health": {
        "enabled": true,
        "interval_seconds": 5,
        "run_on_start": false
      },
      "reconnect": {
        "initial_delay_seconds": 1,
        "max_delay_seconds": 30,
        "multiplier": 2
      }
    },
    "websocket_sources": [
      {
        "source_id": "coinbase-cfm-market-primary",
        "endpoint": "MARKET_DATA",
        "channels": ["level2"],
        "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "include_heartbeats": true
      },
      {
        "source_id": "coinbase-cfm-market-secondary",
        "endpoint": "MARKET_DATA",
        "channels": ["level2"],
        "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "include_heartbeats": true
      },
      {
        "source_id": "coinbase-cfm-user-primary",
        "endpoint": "USER_ORDER_DATA",
        "channels": ["user"],
        "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "include_heartbeats": true
      },
      {
        "source_id": "coinbase-cfm-user-secondary",
        "endpoint": "USER_ORDER_DATA",
        "channels": ["user"],
        "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "include_heartbeats": true
      }
    ],
    "risk": {
      "allowed_products": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
      "allowed_order_types": ["limit"],
      "max_order_size": "1",
      "max_order_notional": "200",
      "max_daily_notional": "400",
      "max_open_orders": 2,
      "max_leverage": "3",
      "require_reduce_only": false,
      "kill_switch_enabled": false
    },
    "product_catalog": {
      "enabled": true,
      "interval_seconds": 3600,
      "run_on_start": true,
      "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"]
    },
    "strategies": {
      "enabled": false,
      "interval_seconds": 5,
      "run_on_start": false,
      "allow_live_execution": false,
      "strategy_ids": ["noop"]
    },
    "reconciliation": {
      "watchdog": {
        "enabled": true,
        "interval_seconds": 5,
        "run_on_start": false,
        "user_confirmation_timeout_seconds": 30,
        "execution_modes": ["live"]
      },
      "order_recovery": {
        "enabled": true,
        "interval_seconds": 30,
        "run_on_start": false
      },
      "fills": {
        "enabled": true,
        "interval_seconds": 30,
        "run_on_start": false,
        "execution_modes": ["live"],
        "limit": 100,
        "max_pages_per_order": 5
      },
      "exchange_state": {
        "enabled": true,
        "interval_seconds": 60,
        "run_on_start": false,
        "account_page_limit": 250,
        "max_account_pages": 10,
        "position_product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "position_size_tolerance": "0"
      }
    },
    "trigger_polling": {
      "enabled": false,
      "interval_seconds": 1,
      "run_on_start": false
    },
    "audit_anchor": {
      "enabled": false,
      "interval_seconds": 86400,
      "run_on_start": false
    },
    "audit_archive": {
      "enabled": false,
      "interval_seconds": 86400,
      "run_on_start": false
    }
  }
}
