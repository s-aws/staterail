{
  "ledger_path": "data/cfm-passive-market-making-release-audit.jsonl",
  "bot": {
    "rest": {
      "execution_mode": "live",
      "retry": {
        "max_attempts": 3,
        "initial_delay_seconds": 0.25,
        "max_delay_seconds": 2,
        "multiplier": 2
      }
    },
    "feed": {
      "min_live_sources": 2,
      "stale_after_seconds": 30,
      "health": {
        "enabled": true,
        "interval_seconds": 5,
        "run_on_start": false
      },
      "reconnect": {
        "initial_delay_seconds": 1,
        "max_delay_seconds": 30,
        "multiplier": 2
      }
    },
    "websocket_sources": [
      {
        "source_id": "coinbase-cfm-market-primary",
        "endpoint": "MARKET_DATA",
        "channels": ["level2"],
        "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "include_heartbeats": true
      },
      {
        "source_id": "coinbase-cfm-market-secondary",
        "endpoint": "MARKET_DATA",
        "channels": ["level2"],
        "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "include_heartbeats": true
      },
      {
        "source_id": "coinbase-cfm-user-primary",
        "endpoint": "USER_ORDER_DATA",
        "channels": ["user"],
        "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "include_heartbeats": true
      },
      {
        "source_id": "coinbase-cfm-user-secondary",
        "endpoint": "USER_ORDER_DATA",
        "channels": ["user"],
        "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "include_heartbeats": true
      }
    ],
    "risk": {
      "allowed_products": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
      "allowed_order_types": ["limit"],
      "max_order_size": "1000",
      "max_order_notional": "200",
      "max_leverage": "3",
      "require_reduce_only": false,
      "kill_switch_enabled": false
    },
    "product_catalog": {
      "enabled": true,
      "interval_seconds": 3600,
      "run_on_start": true,
      "product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"]
    },
    "strategies": {
      "enabled": true,
      "interval_seconds": 5,
      "run_on_start": false,
      "allow_live_execution": true,
      "strategy_ids": ["staged-release-manager"],
      "strategy_parameters": {
        "staged-release-manager": {
          "allow_live_overlap": false,
          "max_releases_per_evaluation": 1
        }
      },
      "operator_policy": {
        "schema_version": 1,
        "policy_name": "passive_market_making_release_cfm_policy_v0",
        "scope": {
          "products": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
          "venue": "coinbase_cfm",
          "live_orders_allowed": true
        },
        "risk_limits": {
          "max_order_notional_usd": "200",
          "max_daily_notional_usd": "400",
          "max_open_orders": 4,
          "allowed_sides": ["buy", "sell"],
          "reduce_only_first": false,
          "kill_switch_enabled": false
        },
        "market_data_requirements": {
          "require_order_book": true,
          "max_order_book_age_seconds": 60,
          "require_product_metadata": true,
          "require_redundant_feeds": true
        },
        "order_behavior": {
          "default_order_type": "limit",
          "default_leverage": "1",
          "default_margin_type": "cross",
          "allow_market_orders": false,
          "post_only": true,
          "time_in_force": "good_until_cancelled"
        },
        "lineage": {
          "model": "flat_root",
          "allow_manual_adoption": false,
          "followup_on_fill": "allowed",
          "move_same_side_orders": "allowed",
          "split_orders": "allowed",
          "merge_orders": "allowed"
        },
        "partial_fills": {
          "followup_enabled": true,
          "followup_size_mode": "percent_of_filled_size",
          "followup_percent": "100",
          "min_followup_notional_usd": "5"
        },
        "moves": {
          "min_price_change_ticks": 1,
          "cooldown_seconds": 10,
          "cancel_replace_when_amend_not_supported": true
        },
        "staged_or_hidden_release": {
          "allow_release": true,
          "enabled": true,
          "release_only_when_conditions_match": true,
          "max_visible_notional_usd": "200"
        }
      }
    },
    "reconciliation": {
      "watchdog": {
        "enabled": true,
        "interval_seconds": 5,
        "run_on_start": false,
        "user_confirmation_timeout_seconds": 30,
        "execution_modes": ["live"]
      },
      "order_recovery": {
        "enabled": true,
        "interval_seconds": 30,
        "run_on_start": false
      },
      "fills": {
        "enabled": true,
        "interval_seconds": 30,
        "run_on_start": false,
        "execution_modes": ["live"],
        "limit": 100,
        "max_pages_per_order": 5
      },
      "exchange_state": {
        "enabled": true,
        "interval_seconds": 60,
        "run_on_start": false,
        "account_page_limit": 250,
        "max_account_pages": 10,
        "position_product_ids": ["REPLACE_WITH_CFM_PRODUCT_IDS"],
        "position_size_tolerance": "0"
      }
    },
    "trigger_polling": {
      "enabled": false,
      "interval_seconds": 1,
      "run_on_start": false
    },
    "audit_anchor": {
      "enabled": false,
      "interval_seconds": 86400,
      "run_on_start": false
    },
    "audit_archive": {
      "enabled": false,
      "interval_seconds": 86400,
      "run_on_start": false
    }
  }
}
