{
  "ledger_path": "data/dry-run-audit.jsonl",
  "bot": {
    "rest": {
      "execution_mode": "dry_run",
      "retry": {
        "max_attempts": 1,
        "initial_delay_seconds": 0.25,
        "max_delay_seconds": 2,
        "multiplier": 2
      }
    },
    "feed": {
      "min_live_sources": 1,
      "stale_after_seconds": 30,
      "health": {
        "enabled": false,
        "interval_seconds": 5,
        "run_on_start": false
      },
      "reconnect": {
        "initial_delay_seconds": 1,
        "max_delay_seconds": 30,
        "multiplier": 2
      }
    },
    "risk": {
      "allowed_products": ["BTC-USD"],
      "allowed_order_types": ["limit"],
      "max_order_size": "1",
      "max_order_notional": "1000",
      "kill_switch_enabled": false
    },
    "product_catalog": {
      "enabled": false,
      "interval_seconds": 3600,
      "run_on_start": false,
      "product_ids": ["BTC-USD"]
    },
    "strategies": {
      "enabled": false,
      "interval_seconds": 1,
      "run_on_start": false,
      "allow_live_execution": false,
      "strategy_ids": ["noop"]
    },
    "reconciliation": {
      "watchdog": {
        "enabled": true,
        "interval_seconds": 5,
        "run_on_start": false,
        "user_confirmation_timeout_seconds": 30,
        "execution_modes": ["live"]
      },
      "order_recovery": {
        "enabled": false,
        "interval_seconds": 30,
        "run_on_start": false
      },
      "fills": {
        "enabled": false,
        "interval_seconds": 30,
        "run_on_start": false,
        "execution_modes": ["live"],
        "limit": 100,
        "max_pages_per_order": 5
      },
      "exchange_state": {
        "enabled": false,
        "interval_seconds": 60,
        "run_on_start": false,
        "account_page_limit": 250,
        "max_account_pages": 10,
        "position_size_tolerance": "0"
      }
    },
    "trigger_polling": {
      "enabled": false,
      "interval_seconds": 1,
      "run_on_start": false
    },
    "triggers": [
      {
        "type": "message",
        "trigger_id": "accepted-data-observer",
        "relation": "on",
        "event_type": "data.accepted",
        "repeatable": true
      }
    ],
    "audit_anchor": {
      "enabled": false,
      "interval_seconds": 86400,
      "run_on_start": false,
      "store": {
        "provider": "local_file",
        "anchor_dir": "anchors"
      }
    },
    "audit_archive": {
      "enabled": false,
      "interval_seconds": 86400,
      "run_on_start": false
    }
  }
}
