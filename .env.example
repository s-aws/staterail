# Safe dry-run defaults. Copy values into your shell environment intentionally;
# this project does not auto-load .env files.
STATERAIL_LEDGER_PATH=data/audit.jsonl
STATERAIL_EXECUTION_MODE=dry_run
STATERAIL_FEED_MIN_LIVE_SOURCES=1
STATERAIL_FEED_STALE_AFTER_SECONDS=30
STATERAIL_FEED_HEALTH_ENABLED=false
STATERAIL_RISK_ALLOWED_PRODUCTS=BTC-USD
STATERAIL_RISK_ALLOWED_ORDER_TYPES=limit
STATERAIL_RISK_MAX_ORDER_SIZE=1
STATERAIL_RISK_MAX_ORDER_NOTIONAL=1000
STATERAIL_PRODUCT_CATALOG_ENABLED=false
STATERAIL_PRODUCT_CATALOG_PRODUCT_IDS=BTC-USD
STATERAIL_STRATEGIES_ENABLED=false
STATERAIL_STRATEGIES_ALLOW_LIVE_EXECUTION=false
# STATERAIL_STRATEGIES_OPERATOR_POLICY_FILE=docs/examples/operator-policy.conservative-cfm-v0.json
# STATERAIL_STRATEGIES_PARAMETERS={"passive-market-making":{"target_notional_usd":"5","half_spread_bps":"50","max_products_per_evaluation":1,"max_staged_release_count_per_side":1},"staged-release-manager":{"max_releases_per_evaluation":1,"allow_live_overlap":false},"followup-on-fill-manager":{"max_followups_per_evaluation":1},"consolidation-manager":{"max_consolidations_per_evaluation":1,"max_source_orders_per_consolidation":2},"anchor-repricing-manager":{"max_moves_per_evaluation":1}}
STATERAIL_STRATEGY_IDS=noop
STATERAIL_WATCHDOG_INTERVAL_SECONDS=5
STATERAIL_TRIGGER_POLLING_ENABLED=false

# Live credentials must be provided only in the operator environment, never here.
# COINBASE_API_KEY=organizations/{org_id}/apiKeys/{key_id}
# COINBASE_API_SECRET=<paste-private-key-contents-in-operator-shell-only>
# STATERAIL_ALLOW_LIVE_TRADING=true
